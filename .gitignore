# --- Secrets / Keys ---
*.pem
*.key
*.crt
*.p12
*.der

# --- OS / Editor ---
.DS_Store
Thumbs.db

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# --- Cache ---
.cache/
.next/cache/
coverage/
tmp/
temp/

# --- TypeScript ---
*.tsbuildinfo
tsconfig.tsbuildinfo

